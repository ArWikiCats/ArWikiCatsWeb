# ArWikiCats Web Service Environment Configuration
# Copy this file to .env and update values as needed

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Path to categories_bot module (optional, for local development)
# Example: ARWIKICATS_PATH=/path/to/categories_bot/make2_new
# in production it should be installed by requirements.txt
ARWIKICATS_PATH=

# Database directory path (default: ~/ArWikiCatsWeb.db)
# Example: DATABASE_PATH=/home/ArWikiCatsWeb.db
DATABASE_PATH=

# Flask environment: development, production
FLASK_ENV=development

# CDN base URL for static assets (optional)
# Example: CDN_BASE=https://tools-static.wmflabs.org/cdnjs/ajax/libs
CDN_BASE=https://tools-static.wmflabs.org/cdnjs/ajax/libs
